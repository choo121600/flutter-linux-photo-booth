#!/bin/bash
# configure hook: exposes print media as snap configuration.
#   snap set ubu4cut print.media=4x6 print.borderless=true
# Values are written to $SNAP_DATA/print-config.env, which run-booth sources.
#
# NOTE: screen rotation is handled by Ubuntu Frame's OUTPUT orientation, e.g.
#   snap set ubuntu-frame display='...orientation: normal|right|inverted|left'
# It is intentionally NOT done in-app: in-app (RotatedBox) rotation rotates the
# picture but not the incoming touch coordinates on Frame's Mir, so taps land in
# the wrong place. Frame output rotation rotates display + touch together.
set -e

media="$(snapctl get print.media || true)"
borderless="$(snapctl get print.borderless || true)"

if [ -z "$media" ]; then
    media="4x6"
    snapctl set print.media="4x6"
fi
if [ -z "$borderless" ]; then
    borderless="true"
    snapctl set print.borderless="true"
fi

case "$borderless" in
    true|false) ;;
    *) echo "print.borderless must be true or false" >&2; exit 1 ;;
esac

mkdir -p "$SNAP_DATA"
umask 022
cat > "$SNAP_DATA/print-config.env" <<EOF
BOOTH_PRINT_MEDIA=$media
BOOTH_PRINT_BORDERLESS=$borderless
EOF

exit 0
