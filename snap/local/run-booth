#!/bin/bash
# Linux Photo Booth launcher — Ubuntu Core (Ubuntu Frame kiosk) + Ubuntu Desktop.
# Wayland-only (Ubuntu Frame and modern desktop sessions are Wayland). The legacy
# X11 fallback and x86-specific GLX tuning were removed; the `gpu` extension now
# provides mesa/gpu-2404, so only app-specific GStreamer/GTK runtime env remains.

# Resolve architecture triplet at runtime.
if [ -n "$CRAFT_ARCH_TRIPLET" ]; then
    ARCH_TRIPLET="$CRAFT_ARCH_TRIPLET"
else
    case "$(uname -m)" in
        aarch64|arm64) ARCH_TRIPLET="aarch64-linux-gnu" ;;
        x86_64)        ARCH_TRIPLET="x86_64-linux-gnu" ;;
        *)             ARCH_TRIPLET="$(uname -m)-linux-gnu" ;;
    esac
fi

# Wayland runtime.
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"
export XDG_SESSION_TYPE=wayland
export GDK_BACKEND=wayland
export GTK_A11Y=none

# Cursor theme (prevents a known GTK cursor segfault).
export XCURSOR_THEME="${XCURSOR_THEME:-DMZ-White}"
export XCURSOR_PATH="$SNAP/usr/share/icons:${XCURSOR_PATH:-/usr/share/icons}"

# Staged GStreamer plugins (USB v4l2 + Raspberry Pi CSI/libcamera).
GST_PATH="$SNAP/usr/lib/$ARCH_TRIPLET/gstreamer-1.0"
export GST_PLUGIN_PATH="$GST_PATH"
export GST_PLUGIN_SYSTEM_PATH="$GST_PATH"
export GST_PLUGIN_SCANNER="$SNAP/usr/libexec/gstreamer-1.0/gst-plugin-scanner"
export GST_REGISTRY="$SNAP_USER_COMMON/gstreamer-1.0/registry.bin"
export GST_REGISTRY_FORK=no
mkdir -p "$SNAP_USER_COMMON/gstreamer-1.0" "$SNAP_USER_COMMON/logs"

# libcamera / libpisp find their IPA modules, IPA proxy, camera tuning, and PiSP
# backend config at their compiled-in /usr paths, which snap `layout:` binds to
# the snap's staged copies (see snapcraft.yaml). No env overrides needed here.

# GTK desktop runtime is provided by the `gnome` extension (gnome-46-2404) via its
# desktop-launch command-chain: pixbuf loaders/cache, fontconfig, xkb, icons, schemas.

# ARM64 (Raspberry Pi 5) GStreamer GL hints.
if [ "$(uname -m)" = "aarch64" ] || [ "$(uname -m)" = "arm64" ]; then
    export GST_GL_PLATFORM=egl
    export GST_GL_API=gles2
fi

# Camera source detection. The Raspberry Pi CSI camera (imx219) exposes many
# /dev/video* ISP/CFE subdevice nodes that CANNOT be captured with v4l2src, so
# only USB (UVC) nodes are treated as v4l2; the CSI path uses libcamera.
# The Dart pipeline reads BOOTH_CAMERA_KIND / DEFAULT_CAMERA_DEVICE.
CAMERA_DEVICE=""
CAMERA_KIND=""
if [ -n "$BOOTH_CAMERA_KIND" ]; then
    # Explicit override (e.g. systemd Environment=BOOTH_CAMERA_KIND=libcamera).
    CAMERA_KIND="$BOOTH_CAMERA_KIND"
    CAMERA_DEVICE="${DEFAULT_CAMERA_DEVICE:-}"
else
    # Prefer a genuine USB (UVC) v4l2 camera; skip CSI ISP/CFE subdevice nodes.
    for n in $(ls /sys/class/video4linux/ 2>/dev/null | grep '^video'); do
        dev="/dev/$n"
        [ -r "$dev" ] || continue
        devpath="$(readlink -f "/sys/class/video4linux/$n/device" 2>/dev/null)"
        case "$devpath" in
            *usb*) CAMERA_DEVICE="$dev"; CAMERA_KIND="v4l2"; break ;;
        esac
    done
    # No USB camera: use libcamera for the Raspberry Pi CSI (imx219 etc.).
    if [ -z "$CAMERA_DEVICE" ] && ls /dev/media* >/dev/null 2>&1; then
        CAMERA_KIND="libcamera"
    fi
fi

[ -n "$CAMERA_DEVICE" ] && export DEFAULT_CAMERA_DEVICE="$CAMERA_DEVICE"
[ -n "$CAMERA_KIND" ] && export BOOTH_CAMERA_KIND="$CAMERA_KIND"
echo "Camera: kind=${CAMERA_KIND:-none} device=${CAMERA_DEVICE:-none}"

# Resolve the Flutter binary.
FLUTTER_BIN=""
for candidate in "$SNAP/bin/linux_photo_booth" "$SNAP/linux_photo_booth"; do
    if [ -x "$candidate" ]; then FLUTTER_BIN="$candidate"; break; fi
done
if [ -z "$FLUTTER_BIN" ]; then
    echo "ERROR: Flutter binary not found under $SNAP" >&2
    exit 1
fi

# Print configuration (media/borderless) written by the configure hook.
if [ -f "$SNAP_DATA/print-config.env" ]; then
    # shellcheck disable=SC1091
    . "$SNAP_DATA/print-config.env"
    export BOOTH_PRINT_MEDIA BOOTH_PRINT_BORDERLESS
fi

echo "Starting Linux Photo Booth ($(date)) — $FLUTTER_BIN"
exec "$FLUTTER_BIN" "$@"
