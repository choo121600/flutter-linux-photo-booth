#!/bin/bash
# Linux Photo Booth Launcher for Ubuntu Core & Ubuntu Desktop
# Optimized for Raspberry Pi 5 (ARM64) and x86_64 platforms

# Resolve architecture triplet at runtime (SNAPCRAFT_ARCH_TRIPLET is build-time only)
if [ -z "$CRAFT_ARCH_TRIPLET" ]; then
    ARCH_TRIPLET=$(dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null)
    if [ -z "$ARCH_TRIPLET" ]; then
        case "$(uname -m)" in
            aarch64|arm64) ARCH_TRIPLET="aarch64-linux-gnu" ;;
            x86_64)        ARCH_TRIPLET="x86_64-linux-gnu" ;;
            *)             ARCH_TRIPLET="$(uname -m)-linux-gnu" ;;
        esac
    fi
else
    ARCH_TRIPLET="$CRAFT_ARCH_TRIPLET"
fi

# Dynamic user runtime directory (Ubuntu Core compatible)
export DISPLAY="${DISPLAY:-:0}"
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-0}"

# Display server detection (Ubuntu Core uses Wayland, Desktop supports both)
if [ -n "$WAYLAND_DISPLAY" ] && [ -S "$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY" ]; then
    export XDG_SESSION_TYPE="wayland"
    export GDK_BACKEND="wayland"
    echo "Using Wayland display server"
else
    export XDG_SESSION_TYPE="x11"
    export GDK_BACKEND="x11"
    echo "Using X11 display server"
fi

# GTK environment (Ubuntu Core optimized)
export GTK_A11Y=none
export GDK_SCALE=1
export GDK_DPI_SCALE=1

# Cursor theme fix (prevents segfault)
export XCURSOR_THEME="DMZ-White"
export XCURSOR_SIZE=24
export XCURSOR_PATH="$SNAP/usr/share/icons:${XCURSOR_PATH:-/usr/share/icons}"

# Architecture-specific optimization
ARCH=$(uname -m)
if [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
    # Raspberry Pi 5 ARM64 optimization
    export MESA_GL_VERSION_OVERRIDE="3.0"
    export GST_GL_PLATFORM=egl
    export GST_GL_API=gles2

    # Raspberry Pi 5 GPU driver settings
    export VC_GPU_ENABLE=1
    export GST_V4L2_USE_LIBV4L2=1

    # GStreamer error handling
    export GST_DEBUG_NO_COLOR=1
    export GST_DEBUG_DUMP_DOT_DIR="$SNAP_USER_COMMON/gst-debug"
    mkdir -p "$SNAP_USER_COMMON/gst-debug"

    echo "ARM64 optimization enabled for Raspberry Pi 5"
else
    # x86_64 optimization
    export MESA_GL_VERSION_OVERRIDE="3.3"
    export GST_GL_PLATFORM=glx
    export GST_GL_API=opengl
    echo "x86_64 optimization enabled"
fi

# GStreamer configuration (runtime paths with resolved arch triplet)
GST_PATH="$SNAP/usr/lib/$ARCH_TRIPLET/gstreamer-1.0"
export GST_PLUGIN_PATH="$GST_PATH"
export GST_PLUGIN_SYSTEM_PATH="$GST_PATH"
export GST_PLUGIN_SCANNER="$SNAP/usr/libexec/gstreamer-1.0/gst-plugin-scanner"
export GST_REGISTRY_FORK=no
export GST_DEBUG=1
export GST_REGISTRY="$SNAP_USER_COMMON/gstreamer-1.0/registry.bin"

# Allow registry generation on first run, skip on subsequent runs
if [ -f "$GST_REGISTRY" ]; then
    export GST_REGISTRY_UPDATE=no
fi

# GDK Pixbuf configuration
export GDK_PIXBUF_MODULE_FILE="$SNAP/usr/lib/$ARCH_TRIPLET/gdk-pixbuf-2.0/2.10.0/loaders.cache"
export GDK_PIXBUF_MODULEDIR="$SNAP/usr/lib/$ARCH_TRIPLET/gdk-pixbuf-2.0/2.10.0/loaders"

# GTK and theme settings
export GTK_PATH="$SNAP/usr/lib/$ARCH_TRIPLET/gtk-3.0"
export XDG_DATA_DIRS="$SNAP/usr/share:${XDG_DATA_DIRS:-/usr/share}"
export XDG_CONFIG_DIRS="$SNAP/etc/xdg:${XDG_CONFIG_DIRS:-/etc/xdg}"

# GIO module configuration
export GIO_MODULE_DIR="$SNAP/usr/lib/$ARCH_TRIPLET/gio/modules"
if [ -d "$GIO_MODULE_DIR" ]; then
    export GIO_EXTRA_MODULES="$GIO_MODULE_DIR"
fi

# Library paths (optimized for snap environment)
export LD_LIBRARY_PATH="$SNAP/lib:$SNAP/usr/lib:$SNAP/usr/lib/$ARCH_TRIPLET:$LD_LIBRARY_PATH"

# Flutter environment
export FLUTTER_ENGINE_SWITCH_TO_IMPELLER=0
export TMPDIR="${SNAP_USER_COMMON:-/tmp}"
export FLUTTER_ENGINE_RUNTIME_MODE=release
export FLUTTER_DPI_SCALE=1.0

# PATH setup
export PATH="$SNAP/usr/bin:$SNAP/bin:$PATH"

# Create required directories
mkdir -p "$SNAP_USER_COMMON/gstreamer-1.0"
mkdir -p "$SNAP_USER_COMMON/logs"

# X11 authentication (if available)
if [ "$XDG_SESSION_TYPE" = "x11" ] && [ -f "$HOME/.Xauthority" ]; then
    export XAUTHORITY="$HOME/.Xauthority"
    echo "X11 authority file found and configured"
fi

# Camera device detection
CAMERA_FOUND=0
USABLE_CAMERA=""

for i in $(seq 0 5); do
    if [ -r "/dev/video$i" ]; then
        if command -v v4l2-ctl >/dev/null 2>&1; then
            CAPS=$(v4l2-ctl --device="/dev/video$i" --list-formats 2>/dev/null | grep -c "YUYV\|RGB\|YUV")
            if [ "$CAPS" -gt 0 ]; then
                echo "Usable camera device found: /dev/video$i"
                CAMERA_FOUND=1
                USABLE_CAMERA="/dev/video$i"
                break
            fi
        else
            echo "Camera device found: /dev/video$i"
            CAMERA_FOUND=1
            USABLE_CAMERA="/dev/video$i"
            break
        fi
    fi
done

if [ $CAMERA_FOUND -eq 0 ]; then
    echo "WARNING: No camera devices accessible!"
    echo "Please run: sudo snap connect linux-photo-booth:camera"
    echo "Available devices: $(ls -1 /dev/video* 2>/dev/null | head -5 | tr '\n' ' ')"
else
    echo "Using camera: $USABLE_CAMERA"
    export DEFAULT_CAMERA_DEVICE="$USABLE_CAMERA"
fi

# Debug info (only when DEBUG=1)
if [ "$DEBUG" = "1" ]; then
    echo "=== Linux Photo Booth Debug Info ==="
    echo "Architecture: $ARCH"
    echo "Arch Triplet: $ARCH_TRIPLET"
    echo "Session Type: $XDG_SESSION_TYPE"
    echo "GDK Backend: $GDK_BACKEND"
    echo "Display: $DISPLAY"
    echo "Wayland: $WAYLAND_DISPLAY"
    echo "Runtime Dir: $XDG_RUNTIME_DIR"
    echo "GST Plugin Path: $GST_PLUGIN_PATH"
    echo "GST Plugin Scanner: $GST_PLUGIN_SCANNER"
    echo "GST Registry: $GST_REGISTRY"
    echo "LD Library Path: ${LD_LIBRARY_PATH:0:200}..."
    echo "=================================="
fi

# Resolve Flutter binary path
FLUTTER_BIN=""
for candidate in "$SNAP/bin/linux_photo_booth" "$SNAP/linux_photo_booth"; do
    if [ -x "$candidate" ]; then
        FLUTTER_BIN="$candidate"
        break
    fi
done

if [ -z "$FLUTTER_BIN" ]; then
    echo "ERROR: Flutter binary not found!"
    echo "Searched: $SNAP/bin/linux_photo_booth, $SNAP/linux_photo_booth"
    ls -la "$SNAP/bin/" 2>/dev/null
    exit 1
fi

# Launch application
echo "Starting Linux Photo Booth ($(date))..."
echo "Binary: $FLUTTER_BIN"

if [ "$DEBUG" = "1" ]; then
    exec "$FLUTTER_BIN" "$@" 2>&1 | tee "$SNAP_USER_COMMON/logs/app.log"
else
    "$FLUTTER_BIN" "$@" 2>"$SNAP_USER_COMMON/logs/error.log" | tee "$SNAP_USER_COMMON/logs/app.log"
    EXIT_CODE=$?

    if [ $EXIT_CODE -ne 0 ]; then
        echo "Application exited with code $EXIT_CODE"
        echo "Check logs: $SNAP_USER_COMMON/logs/"
        exit $EXIT_CODE
    fi
fi
